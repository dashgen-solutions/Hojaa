# ============================================================
# Hojaa Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# At minimum, you need ONE LLM provider API key.
# ============================================================

# --- LLM Provider Selection ---
# Which provider to use by default: openai | anthropic | azure | ollama
LLM_PROVIDER=openai

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Anthropic ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# --- Azure OpenAI (enterprise deployments) ---
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=                   # https://YOUR-RESOURCE.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=                 # your-gpt4-deployment-name
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# --- Ollama (local/offline, no data leaves your machine) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# --- Database ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hojaa_db

# --- Security ---
SECRET_KEY=change-me-to-a-random-64-char-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- CORS ---
CORS_ORIGINS=["http://localhost:3000"]

# --- SMTP Email ---
# GoDaddy Professional Email (default) or any SMTP provider.
# For Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_USE_TLS=true
#
# Docker Compose (repo root): copy these lines into the .env next to docker-compose.yml
# so the `api` service receives them. Quote app passwords if they contain spaces:
#   SMTP_PASSWORD="abcd efgh ijkl mnop"
SMTP_ENABLED=false
SMTP_HOST=smtpout.secureserver.net
SMTP_PORT=465
SMTP_USERNAME=contact@hojaa.com
SMTP_PASSWORD=
SMTP_FROM_EMAIL=contact@hojaa.com
SMTP_FROM_NAME=Hojaa
SMTP_USE_TLS=false

# --- Platform Admin (optional) ---
PLATFORM_ADMIN_EMAIL=contact@hojaa.com
PLATFORM_ADMIN_PASSWORD=
