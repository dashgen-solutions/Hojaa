hojaa.com {
	# API and WebSocket routes
	handle /api/* {
		reverse_proxy api:8000
	}
	handle /ws/* {
		reverse_proxy api:8000
	}
	handle /health {
		reverse_proxy api:8000
	}

	# Frontend (everything else)
	handle {
		reverse_proxy web:3000
	}
}

# Redirect www to apex
www.hojaa.com {
	redir https://hojaa.com{uri} permanent
}
